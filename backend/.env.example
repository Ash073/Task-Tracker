PORT=5000
JWT_SECRET=your_jwt_secret_key_change_this

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your_supabase_anon_key

# Developer API Keys (optional - fallback when user key missing)
DEV_GEMINI_API_KEY=
DEV_OPENAI_API_KEY=

# AI mode: auto | gemini | openai | local
DEFAULT_AI_MODE=auto

# Cache TTL in seconds for AI quotes
QUOTE_CACHE_TTL=3600

# Push notification (optional - Web Push)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@tasktracker.app
